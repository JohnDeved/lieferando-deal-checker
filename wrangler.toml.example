# Copy to `wrangler.toml` and replace the KV namespace `id` with your own
# (`npx wrangler kv namespace create DEALS_KV`).
name = "lieferando-deal-checker"
main = "src/index.ts"
compatibility_date = "2026-05-14"

[triggers]
crons = ["*/30 * * * *"]

[[kv_namespaces]]
binding = "DEALS_KV"
id = "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"
